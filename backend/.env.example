PORT=8081
REDIS_URL=redis://localhost:6379
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override the Gemini model used for decoy generation.
# Default: gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.0-flash-lite

# I7: OPENAI_API_KEY — required when using OpenAI as the decoy LLM backend
# or for session analysis via AnalyzeText. Leave empty to disable OpenAI.
# Generate/obtain at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

HONEYPOT_RISK_THRESHOLD=0.6
CORS_ORIGINS=http://localhost:3000,https://mirage-frontend.vercel.app
LOBSTER_TRAP_URL=http://localhost:8080
# RECOMMENDED: dedicated credential for Lobster Trap (principle of least privilege).
# Falls back to GEMINI_API_KEY/OPENAI_API_KEY if not set (warning logged at startup).
LOBSTER_API_KEY=
LOBSTER_TRAP_POLICY_PATH=./mirage_policy.yaml
LOBSTER_TRAP_AUDIT_LOG=./lobstertrap.jsonl

# Model forwarded to Lobster Trap for DPI analysis.
# Must match a model supported by the Lobster Trap service.
# Default: gemini-2.0-flash
LOBSTER_MODEL=gemini-2.0-flash

# REQUIRED: Dashboard API key — must be set explicitly, no default.
# Used for X-API-Key header on /api/v1/* and as WebSocket token (?token=...).
# Generate with: openssl rand -hex 32
API_KEY=your_dashboard_api_key_here

# RECOMMENDED: AES-256-GCM key for encrypting integration secrets at rest in Redis.
# If not set, secrets are stored unencrypted (warning logged at startup).
# Generate with: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=

# I7: PROMPTS_DIR — directory containing persona prompt .txt files.
# Defaults to ./prompts relative to the binary if not set.
# Example: PROMPTS_DIR=/etc/mirage/prompts
PROMPTS_DIR=./prompts

DEMO_MODE=true
LOG_FORMAT=json
LOG_LEVEL=info

# APP_ENV controls production guards (e.g. NoopEncryptor panics when set to
# "production" without SECRET_ENCRYPTION_KEY). Set to "production" in live
# deployments to catch misconfigurations at startup.
# Default: development (no guard)
APP_ENV=development
